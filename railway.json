{
  "builds": [
    {
      "src": "server/package.json",
      "use": "@railway/node",
      "config": {
        "runtime": "16.x"
      }
    },
    {
      "src": "client/package.json",
      "use": "@railway/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ],
  "variables": {
    "MONGODB_URI": {
      "description": "رابط اتصال MongoDB",
      "required": true
    },
    "JWT_SECRET": {
      "description": "مفتاح تشفير JWT",
      "required": true
    },
    "SMTP_USER": {
      "description": "بريد SMTP للإشعارات",
      "required": false
    }
  }
}